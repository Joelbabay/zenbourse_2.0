{% extends 'base.html.twig' %} {% block title %} Zenbourse - Liste des valeurs
{% endblock %} {% block body %} {% include 'partials/header.html.twig' %}

<main class="custom-container mt-4">
  <div class="row g-5">
    <div class="col-md-9 mt-4">
      <div class="mt-3">
        <h2 class="fst-italic border-bottom pb-4 mb-3">
          {{ specialPage.title }}
        </h2>
        {% if specialPage.content %}
          <div class="dynamic-content">
            {{ specialPage.content|raw }}
          </div>
        {% endif %}
      </div>
      {% if app.user %}
      <div class="row col-md-6 m-auto p-4">
        <a
          href="{{ path('download_thank_you') }}"
          class="btn btn-lg btn-light text-light zen-button"
          >Je télécharge la liste des valeurs de l’étude statistique</a
        >
      </div>
      {% else %}
      <div class="bg-light rounded">
        <div class="row col-md-8 mx-auto p-3">
          {{ form(form, {'attr': {'data-turbo': 'false'}}) }}
        </div>
      </div>
      {% endif %}
    </div>
    <div class="col-md-3">{% include 'home/widgets/sidebar.html.twig' %}</div>
  </div>
</main>

{% endblock %}
