{# templates/admin/user/send_email.html.twig #}
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    <i class="fas fa-envelope"></i> Envoyer un email à {{ user.fullName }}
{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0 text-white">
                <i class="fas fa-user me-2"></i>
                Destinataire : {{ user.firstname }} {{ user.lastname }}
            </h5>
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                <strong>Email :</strong> {{ user.email }}
            </div>

            {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_row(form.subject, {
                        'attr': {'class': 'form-control'}
                    }) }}
                </div>

                <div class="mb-3">
                    {{ form_row(form.message, {
                        'attr': {'class': 'form-control'}
                    }) }}
                </div>

                <div class="d-flex justify-content-between">
                    <a href="{{ ea_url().setAction('index') }}" class="btn btn-secondary">
                        <i class="fas fa-times me-2"></i>Annuler
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane me-2"></i>Envoyer l'email
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header">
            <h6 class="mb-0"><i class="fas fa-lightbulb me-2"></i>Variables disponibles</h6>
        </div>
        <div class="card-body">
            <p class="mb-2">Vous pouvez personnaliser votre message. Les informations suivantes seront automatiquement ajoutées :</p>
            <ul class="mb-0">
                <li><strong>Salutation :</strong> Bonjour {{ user.civility }} {{ user.lastname }}</li>
                <li><strong>Signature :</strong> L'équipe Zenbourse</li>
                <li><strong>Mise en forme :</strong> Les sauts de ligne seront préservés</li>
            </ul>
        </div>
    </div>
{% endblock %}