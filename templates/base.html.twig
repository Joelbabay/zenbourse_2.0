<!DOCTYPE html>
<html data-turbo="false">
  <head>
    <meta charset="UTF-8" />
    <title>{% block title %}{% endblock %}</title>
    <script src="//ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js"></script>
    <link
      rel="icon"
      type="image/jpg"
      href="{{ asset('images/zenbourse-logo.svg') }}"
    />
    <!--<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">-->
    <link href="/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="{{ asset('css/magnific-popup.css') }}" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <script src="/js/bootstrap.bundle.js"></script>
    <script
      src="https://kit.fontawesome.com/54fca6d779.js"
      crossorigin="anonymous"
    ></script>
    <link href="/css/style.css" rel="stylesheet" />

    {% block stylesheets %}{% endblock %} {% block javascripts %} {% block
    importmap %}
    {{
      importmap("app")
    }}
    {% endblock %} {% endblock %}
  </head>
  <body>
    {# Modal Bootstrap pour afficher les graphiques de tickers #}
    <div class="modal fade" id="tickerModal" tabindex="-1" aria-labelledby="tickerModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="tickerModalLabel">Graphique</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer">
            </button>
          </div>
          <div class="modal-body text-center">
            <img id="tickerModalImg" src="" alt="Graphique du ticker" class="img-fluid"/>
          </div>
        </div>
      </div>
    </div>

    <div class="modal fade" id="welcomeModal" tabindex="-1" aria-labelledby="welcomeModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 1.2rem">
          <div class="modal-header" style="background: linear-gradient(90deg, #0d6efd 0%, #00c9a7 100%);border-top-left-radius: 1.2rem;border-top-right-radius: 1.2rem;">
            <h5 class="modal-title text-white fw-bold" id="welcomeModalLabel">
              {{ config('welcome_modal_title')|raw }}
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"aria-label="Fermer">
            </button>
          </div>
          <div class="modal-body text-center py-5" style="background: #f8f9fa">
            {{ config('welcome_modal_content')|raw }}
          </div>
        </div>
      </div>
    </div>

    <div id="main-content">
      {% block body %}
      {% endblock %}
    </div>

    {% if app.request.attributes.get('crudControllerFqcn') is null %}
      {{ include('partials/admin_floating_button.html.twig') }}
    {% endif %}

    {% include 'partials/footer.html.twig' %}

    <script src="/js/jquery.magnific-popup.js"></script>
    <script src="{{ asset('js/app.js') }}"></script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {

        if (!sessionStorage.getItem("zenbourse_welcome_shown")) {
          var welcomeModal = new bootstrap.Modal(
            document.getElementById("welcomeModal")
          );
          welcomeModal.show();
          sessionStorage.setItem("zenbourse_welcome_shown", "1");
        }

        document
          .querySelectorAll('a[href*="/images/performances/"]')
          .forEach(function (link) {
            link.classList.add("ticker-link");
          });

        document.querySelectorAll(".ticker-link").forEach(function (link) {
          var imgSrc = link.getAttribute('href');
          if (imgSrc) {
              var img = new Image();
              img.src = imgSrc;
          }

          link.addEventListener("click", function (e) {
              e.preventDefault();
              var imgSrc = this.getAttribute("href");
              var modalImg = document.getElementById("tickerModalImg");
              modalImg.src = ""; // Vide l'image précédente
              modalImg.alt = "Chargement...";
              // Affiche un loader ici si tu veux
              var modal = new bootstrap.Modal(document.getElementById("tickerModal"));
              modal.show();
              // Charge l'image
              var img = new Image();
              img.onload = function() {
                  modalImg.src = imgSrc;
                  modalImg.alt = "Graphique du ticker";
              };
              img.src = imgSrc;
            });
        });
      });

      function populateH2List() {
        const mainContent = document.getElementById("main-content");
        if (!mainContent) return;

        const h2List = document.getElementById("h2-list");
        const sidebarContainer = h2List.closest(".sidebar");

        h2List.innerHTML = "";

        // Sélectionne uniquement les h2/h3 dans le contenu principal
        const headings = Array.from(mainContent.querySelectorAll("h2, h3"));

        if (headings.length === 0) {
          if (sidebarContainer) {
            sidebarContainer.style.display = "none";
          }
          return;
        } else {
          if (sidebarContainer) {
            sidebarContainer.style.display = "";
          }
        }

        headings.forEach((heading, index) => {
          if (!heading.id) {
            heading.id = `section-${index + 1}`;
          }

          const listItem = document.createElement("li");
          const link = document.createElement("a");
          link.href = `#${heading.id}`;
          link.textContent = heading.textContent.trim();
          link.style.cursor = "pointer";
          link.style.textDecoration = "none";

          if (heading.tagName.toLowerCase() === "h3") {
            listItem.classList.add("sidebar-h3");
          }

          listItem.appendChild(link);
          h2List.appendChild(listItem);
        });
      }

      document.addEventListener("DOMContentLoaded", populateH2List);
      document.addEventListener("turbo:load", populateH2List);

      document.querySelectorAll(".clickable-div").forEach(function (div) {
        div.addEventListener("click", function (e) {
          // Si le clic vient d'un lien, on laisse le lien fonctionner normalement
          if (e.target.closest("a")) return;
          window.location = div.getAttribute("data-href");
        });
      });

      // Fonction pour mettre à jour la marge dynamique
      function updateScrollMargin() {
        // Sélectionnez le header sticky
        const header = document.querySelector(".sticky-top");

        // Vérifiez si le header existe
        if (header) {
          const headerHeight = Math.ceil(header.getBoundingClientRect().height);

          // Ajoutez le scroll-margin-top à tous les éléments ciblés (par exemple, h2)
          document.querySelectorAll("h2, h3").forEach((element) => {
            element.style.scrollMarginTop = `${headerHeight + 10}px`; // +10 pour un peu d'espacement
          });
        }
      }
      updateScrollMargin();
      window.addEventListener("resize", updateScrollMargin);
    </script>
  </body>
</html>
